<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_bg_color"> <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingHorizontal="24dp"
    android:paddingTop="32dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="24dp">

        <TextView
            android:id="@+id/tv_month_year_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Tháng 05 năm 2026"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/app_text_primary"
            android:letterSpacing="-0.02"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_back_to_today"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="Hôm nay"
            android:textColor="@color/app_primary_color"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginEnd="4dp"
            app:icon="@android:drawable/ic_menu_today"
            app:iconSize="18dp"
            app:iconTint="@color/app_primary_color"
            app:cornerRadius="12dp"/>

        <ImageButton
            android:id="@+id/btn_previous_month"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_media_previous"
            android:contentDescription="Tháng trước"
            app:tint="@color/app_text_secondary"/>

        <ImageButton
            android:id="@+id/btn_next_month"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_media_next"
            android:contentDescription="Tháng sau"
            app:tint="@color/app_text_secondary"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_weekday_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="CN" android:textColor="@color/app_error_color" android:textStyle="bold" android:gravity="center" android:textSize="13sp"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="T2" android:textColor="@color/app_text_secondary" android:textStyle="bold" android:gravity="center" android:textSize="13sp"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="T3" android:textColor="@color/app_text_secondary" android:textStyle="bold" android:gravity="center" android:textSize="13sp"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="T4" android:textColor="@color/app_text_secondary" android:textStyle="bold" android:gravity="center" android:textSize="13sp"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="T5" android:textColor="@color/app_text_secondary" android:textStyle="bold" android:gravity="center" android:textSize="13sp"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="T6" android:textColor="@color/app_text_secondary" android:textStyle="bold" android:gravity="center" android:textSize="13sp"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="T7" android:textColor="@color/app_text_secondary" android:textStyle="bold" android:gravity="center" android:textSize="13sp"/>
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_calendar_grid"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        android:overScrollMode="never"/>
</LinearLayout>

    <LinearLayout
        android:id="@+id/layout_agenda_sheet"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@drawable/bg_bottom_sheet_rounded"
        android:elevation="24dp"
        app:behavior_hideable="true"
        app:behavior_peekHeight="320dp"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior">

        <View
            android:layout_width="48dp"
            android:layout_height="5dp"
            android:background="@drawable/bg_drag_handle"
            android:layout_gravity="center"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="12dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="24dp"
            android:paddingVertical="8dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_selected_date_header"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Lịch trình Hôm nay"
                android:textColor="@color/app_text_primary"
                android:textStyle="bold"
                android:textSize="18sp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_smart_suggest"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:text="Gợi ý tối ưu"
                android:textColor="@color/app_success_color"
                android:textSize="13sp"
                android:textStyle="bold"
                app:backgroundTint="@color/app_success_light"
                app:cornerRadius="12dp"
                app:elevation="0dp"
                app:icon="@android:drawable/ic_menu_compass"
                app:iconTint="@color/app_success_color"
                app:iconSize="16dp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layout_empty_state"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone"
            android:paddingBottom="64dp"
            android:paddingHorizontal="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="☕"
                android:textSize="56sp"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ngày nghỉ thảnh thơi"
                android:textColor="@color/app_text_primary"
                android:textStyle="bold"
                android:textSize="18sp"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bạn chưa có lịch trình nào cho ngày này. Hãy tận hưởng thời gian nghỉ ngơi nhé!"
                android:textColor="@color/app_text_secondary"
                android:textSize="14sp"
                android:gravity="center"
                android:lineSpacingExtra="4dp"/>
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_calendar_tasks"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingHorizontal="20dp"
            android:paddingTop="8dp"
            android:clipToPadding="false"
            android:paddingBottom="40dp"
            android:scrollbars="none"/>
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>