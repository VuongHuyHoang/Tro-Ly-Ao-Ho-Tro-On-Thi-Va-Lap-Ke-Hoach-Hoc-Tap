<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/backgroundColor"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingTop="24dp"
        android:paddingBottom="24dp"
        android:layout_marginBottom="16dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="80dp"
            android:layout_height="80dp"
            app:cardCornerRadius="40dp"
            app:cardBackgroundColor="@color/primaryColor"
            app:strokeWidth="0dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/tv_avatar_text"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="US"
                android:textColor="@color/surfaceColor"
                android:textSize="28sp"
                android:textStyle="bold"
                android:gravity="center"/>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tv_profile_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Đang tải..."
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/textColor"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/tv_profile_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MSSV: -- | Lớp: --"
            android:textSize="14sp"
            android:textColor="@color/hintColor"/>

        <TextView
            android:id="@+id/tv_profile_highscore"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Điểm trắc nghiệm cao nhất: 0/3"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/primaryColor"
            android:layout_marginTop="4dp"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="2"
        android:layout_marginBottom="24dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="@color/surfaceColor"
            app:strokeWidth="1dp"
            app:strokeColor="@color/borderColor">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:gravity="center">
                <TextView
                    android:id="@+id/tv_count_done"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="#2E7D32"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Đã hoàn thành"
                    android:textSize="12sp"
                    android:textColor="@color/hintColor"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="@color/surfaceColor"
            app:strokeWidth="1dp"
            app:strokeColor="@color/borderColor">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:gravity="center">
                <TextView
                    android:id="@+id/tv_count_pending"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="#C62828"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Đang chờ xử lý"
                    android:textSize="12sp"
                    android:textColor="@color/hintColor"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_edit_profile"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="Chỉnh sửa thông tin hồ sơ"
        android:textColor="@color/primaryColor"
        app:backgroundTint="@color/surfaceColor"
        app:strokeColor="@color/primaryColor"
        app:strokeWidth="1dp"
        app:cornerRadius="12dp"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginBottom="12dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_logout"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="Đăng xuất tài khoản"
        android:textColor="#C62828"
        app:backgroundTint="@color/surfaceColor"
        app:strokeColor="#C62828"
        app:strokeWidth="1dp"
        app:cornerRadius="12dp"
        android:textSize="14sp"
        android:textStyle="bold"/>
</LinearLayout>