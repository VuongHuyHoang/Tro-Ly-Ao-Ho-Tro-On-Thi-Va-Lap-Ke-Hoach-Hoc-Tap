<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/backgroundColor">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/tv_quiz_progress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Câu hỏi: 1 / 3"
            android:textColor="@color/primaryColor"
            android:textStyle="bold"
            android:textSize="14sp"
            android:layout_marginBottom="12dp"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="@color/surfaceColor"
            app:strokeWidth="0dp"
            android:layout_marginBottom="24dp">
            <TextView
                android:id="@+id/tv_quiz_question"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nội dung câu hỏi trắc nghiệm?"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/textColorPrimary"
                android:padding="20dp"
                android:lineSpacingMultiplier="1.2"/>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_option_0"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Đáp án A"
            android:gravity="start|center_vertical"
            android:paddingStart="20dp"
            android:layout_marginBottom="12dp"
            app:backgroundTint="@color/surfaceColor"
            android:textColor="@color/textColorPrimary"
            app:strokeColor="#E0E0E0" app:strokeWidth="1dp"
            app:cornerRadius="12dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_option_1"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Đáp án B"
            android:gravity="start|center_vertical"
            android:paddingStart="20dp"
            android:layout_marginBottom="12dp"
            app:backgroundTint="@color/surfaceColor"
            android:textColor="@color/textColorPrimary"
            app:strokeColor="#E0E0E0" app:strokeWidth="1dp"
            app:cornerRadius="12dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_option_2"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Đáp án C"
            android:gravity="start|center_vertical"
            android:paddingStart="20dp"
            android:layout_marginBottom="12dp"
            app:backgroundTint="@color/surfaceColor"
            android:textColor="@color/textColorPrimary"
            app:strokeColor="#E0E0E0" app:strokeWidth="1dp"
            app:cornerRadius="12dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_option_3"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Đáp án D"
            android:gravity="start|center_vertical"
            android:paddingStart="20dp"
            android:layout_marginBottom="20dp"
            app:backgroundTint="@color/surfaceColor"
            android:textColor="@color/textColorPrimary"
            app:strokeColor="#E0E0E0" app:strokeWidth="1dp"
            app:cornerRadius="12dp"/>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_explanation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="12dp"
            app:strokeWidth="1dp"
            app:strokeColor="#B3E5FC"
            app:cardBackgroundColor="#E1F5FE"
            android:visibility="gone">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💡 Giải thích từ Trợ lý AI:"
                    android:textStyle="bold"
                    android:textColor="#0288D1"
                    android:textSize="14sp"
                    />
                <TextView
                    android:id="@+id/tv_quiz_explanation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Nội dung giải thích..."
                    android:textColor="#01579B"
                    android:textSize="14sp"
                    android:lineSpacingMultiplier="1.1"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_next_question"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="Câu Tiếp Theo ➔"
            android:textSize="15sp"
            android:textStyle="bold"
            app:cornerRadius="12dp"
            android:visibility="gone"/>
    </LinearLayout>
</ScrollView>